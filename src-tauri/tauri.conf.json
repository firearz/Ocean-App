{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ocean",
  "version": "0.1.0",
  "identifier": "com.ocean.focustimer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ocean — Focus Timer",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false
      },
      {
        "label": "mini",
        "title": "Ocean Mini",
        "width": 220,
        "height": 72,
        "url": "/#/mini",
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "center": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
